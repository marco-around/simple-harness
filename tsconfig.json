{
	"$schema": "https://www.schemastore.org/tsconfig",
	"display": "Node 24",
	"_version": "24.0.0",

	"compilerOptions": {
		"lib": [
			"es2024",
			"ESNext.Array",
			"ESNext.Collection",
			"ESNext.Error",
			"ESNext.Iterator",
			"ESNext.Promise"
		],
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "nodenext",
		"target": "es2024",
		"jsx": "react-jsx",

		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"moduleResolution": "node16",
		"types": ["node"]
	}
}
